# =============================================================================
# Dockerfile — zdrav.lenreg Telegram Bot
# =============================================================================
# Основа: python:3.11-slim (минимальный образ, ~120MB)
# Запуск: python -m src.main (асинхронный поллинг aiogram)
# =============================================================================

FROM python:3.11-slim AS builder

# ---------------------------------------------------------------------------
# Метки образа
# ---------------------------------------------------------------------------
LABEL maintainer="acidmsg"
LABEL description="Telegram-бот для мониторинга талонов zdrav.lenreg.ru"
LABEL version="1.0.0"
LABEL org.opencontainers.image.source="https://github.com/acidmsg/zdrav.lenreg"

# ---------------------------------------------------------------------------
# Системные зависимости — минимально необходимые для сборки
# ---------------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt \
  apt-get update && \
  apt-get install -y --no-install-recommends \
  gcc \
  libc6-dev \
  && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Установка Python-зависимостей в отдельный слой (кеширование)
# ---------------------------------------------------------------------------
WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir --user -r requirements.txt

# =============================================================================
# Финальный образ
# =============================================================================
FROM python:3.11-slim

# ---------------------------------------------------------------------------
# Метки (дублируем — финальный слой переопределяет их)
# ---------------------------------------------------------------------------
LABEL maintainer="acidmsg"
LABEL description="Telegram-бот для мониторинга талонов zdrav.lenreg.ru"
LABEL version="1.0.0"
LABEL org.opencontainers.image.source="https://github.com/acidmsg/zdrav.lenreg"

# ---------------------------------------------------------------------------
# Системные зависимости для рантайма (минимально)
# ---------------------------------------------------------------------------
RUN --mount=type=cache,target=/var/cache/apt \
  apt-get update && \
  apt-get install -y --no-install-recommends \
  # ps для healthcheck
  procps \
  # sqlite3 — опционально, для отладки
  sqlite3 \
  && rm -rf /var/lib/apt/lists/*

# ---------------------------------------------------------------------------
# Создание непривилегированного пользователя
# ---------------------------------------------------------------------------
RUN groupadd -r appuser && \
  useradd -r -g appuser -d /app -s /sbin/nologin -c "App User" appuser

# ---------------------------------------------------------------------------
# Копирование зависимостей из builder-слоя
# ---------------------------------------------------------------------------
COPY --from=builder /root/.local /root/.local
ENV PATH=/root/.local/bin:$PATH

# ---------------------------------------------------------------------------
# Копирование исходного кода
# ---------------------------------------------------------------------------
WORKDIR /app
COPY src/ src/

# ---------------------------------------------------------------------------
# Директория для runtime-данных (SQLite, кэш)
# Монтируется извне через docker-compose volume: ./data:/app/data
# ---------------------------------------------------------------------------
RUN mkdir -p /app/data && \
  chown -R appuser:appuser /app

# ---------------------------------------------------------------------------
# Переключение на непривилегированного пользователя
# ---------------------------------------------------------------------------
USER appuser

# ---------------------------------------------------------------------------
# Healthcheck — проверяет, что процесс python жив и читаем SQLite
# ---------------------------------------------------------------------------
EXPOSE 9090

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD python -c "import os; os.access('data/bot.db', os.R_OK | os.W_OK) or exit(1)" || exit 1

# ---------------------------------------------------------------------------
# Точка входа
# ---------------------------------------------------------------------------
ENTRYPOINT ["python", "-m", "src.main"]
