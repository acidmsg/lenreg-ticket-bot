# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token_here

# Proxy Configuration
# Используйте "auto" как хост для автоопределения IP прокси при старте
# (сканирование Docker/WSL подсетей 172.17-31.0.0/16 на заданном порту)
# Для фиксированного адреса: socks5://172.17.16.1:10808
PROXY_URL=socks5://auto:10808

# File Paths
SQLITE_DB_PATH=data/bot.db
CACHE_PATH=data/monitoring_cache.json

# Redis
REDIS_URL=redis://localhost:6379/0

# Пароль для Redis (требуется при подключении извне контейнера) — SECRET
REDIS_PASSWORD=your_redis_password_here

# Patient IDs for doctor discovery (used to fetch speciality lists)
DISCOVERY_PATIENT_ID_ADULT=your_adult_patient_id_here
DISCOVERY_PATIENT_ID_CHILD=your_child_patient_id_here

# Admin Telegram ID(s) for /status command (comma-separated, e.g.: your_telegram_id or your_telegram_id,another_id)
ADMIN_IDS=your_telegram_id_here

# === Error notifications (M2) ===
# Enable/disable error notifications globally (can be overridden in DB config)
ERROR_NOTIFY_ENABLED=True

# NTFY topic URL for push notifications — SECRET
NTFY_TOPIC_URL=your_ntfy_topic_url_here

# Sentry DSN for error tracking — SECRET
SENTRY_DSN=your_sentry_dsn_here

# Environment tag for Sentry (can be overridden in DB config)
ENVIRONMENT=production

# Пороги для форматирования списка номерков
# Макс. слотов на одну дату для детального отображения (больше — диапазон)
SLOT_DETAIL_THRESHOLD=10
# Макс. слотов всего для детального отображения (больше — компактно)
SLOT_COMPACT_THRESHOLD=15

# === Rate limiting (M3) ===
# Max messages per user per time window (can be overridden in DB config)
USER_RATE_LIMIT_MAX=30
USER_RATE_LIMIT_PERIOD=60

# === Metrics (Prometheus) ===
# Порт для HTTP-endpoint /metrics
METRICS_PORT=9090

# === API Versioning ===
# Версия API-клиента (передаётся в заголовке X-Client-Version)
API_VERSION=1.0.0
# Валидация ответов API через Pydantic-схемы (True/False)
API_VALIDATE_RESPONSES=True

# === i18n ===
# Язык интерфейса бота (ru, en)
BOT_LANGUAGE=ru

# === API zdrav.lenreg.ru ===
# Базовый URL API портала zdrav.lenreg.ru
API_BASE_URL=https://zdrav.lenreg.ru/api

# Referer для HTTP-заголовков
REFERER_URL=https://zdrav.lenreg.ru/signup/free/

# Origin для HTTP-заголовков
ORIGIN_URL=https://zdrav.lenreg.ru

# CSRF-токен для запросов к API — статический, всегда NOTPROVIDED
CSRF_TOKEN=NOTPROVIDED

# ID района по умолчанию для получения списка клиник
DISTRICT_ID=4

# === Идентификаторы по умолчанию ===
# Клиника по умолчанию для первичного поиска пациента
DEFAULT_CLINIC_ID=272

# ID стоматологической клиники (для фильтрации детских/взрослых специальностей)
DENTAL_CLINIC_ID=272

# Дефолтная дата рождения для новых пациентов без даты
DEFAULT_BIRTHDAY=1990-01-01

# Публичная ссылка для записи (отображается в уведомлениях)
SIGNUP_URL=https://zdrav.lenreg.ru/signup/free/

# === Intervals ===
# Интервал healthcheck-проверки (секунд, 5 минут)
CHECK_INTERVAL=300
# Интервал discovery врачей (секунд, 30 минут)
DISCOVERY_INTERVAL=1800
# Интервал проверки автоудаления сообщений (секунд, 1 час)
CLEANUP_INTERVAL=3600

# === Qdrant (Codebase Indexing) ===
# URL подключения к Qdrant
QDRANT_URL=http://qdrant:6333
# API-ключ для Qdrant (если включена аутентификация) — SECRET
QDRANT_API_KEY=your_qdrant_api_key_here

# === API Schema Change Detection (F8) ===
# Интервал проверки схем API (секунды, 3600 = 1 час)
SCHEMA_CHECK_INTERVAL=3600
# Включить проверку схем API (true/false)
SCHEMA_CHECK_ENABLED=true

# === Web Dashboard (F5) ===
# Включить веб-дашборд (True/False, можно переопределить в БД)
WEB_DASHBOARD_ENABLED=True
# Порт для веб-дашборда (можно переопределить в БД).
# При использовании Cloudflare Proxy — порт из списка: 80, 8080, 8880, 2052, 2082, 2086, 2095.
WEB_DASHBOARD_PORT=8080
# API-ключ для доступа к дашборду — SECRET, пустая строка = без аутентификации
WEB_DASHBOARD_API_KEY=your_dashboard_api_key_here

# === Mini App (F10) ===
# Включить поддержку Telegram Mini App (True/False)
MINI_APP_ENABLED=True
# Максимальный возраст initData (секунд, 86400 = 24 часа)
MINI_APP_INITDATA_MAX_AGE=86400
# URL Mini App для кнопки web_app в Telegram (HTTPS обязателен для production).
# Для Cloudflare Proxy используйте порт из списка поддерживаемых:
# 80, 8080, 8880, 2052, 2082, 2086, 2095 (HTTP).
MINI_APP_URL=https://your-domain.example/app/

# === Python / Encoding ===

# Включает Python UTF-8 Mode (PEP 540) — sys.stdout.encoding = utf-8
# Устраняет кракозябры в pwsh на Windows с русской локалью.
PYTHONUTF8=1

# === Backup (F13) ===
# Корневая директория для хранения бэкапов (на хосте: /root/backups, в контейнере: /app/backups)
BACKUP_DIR=data/backups
# Количество хранимых daily-бэкапов
BACKUP_DAILY_RETENTION=7
# Количество хранимых weekly-бэкапов
BACKUP_WEEKLY_RETENTION=4
# Количество хранимых monthly-бэкапов
BACKUP_MONTHLY_RETENTION=3
# Количество хранимых manual-бэкапов (ручные из дашборда)
BACKUP_MANUAL_RETENTION=10
# NTFY-топик для алертов системы бэкапов (опционально) — SECRET
NTFY_BACKUP_TOPIC=your_ntfy_backup_topic_here
# Режим восстановления: true — в контейнере (без docker compose), false — на хосте
RESTORE_IN_CONTAINER=false

# === Таймауты и пороги ===
# Таймаут HTTP-запросов к API (секунды)
API_TIMEOUT=10.0
# Абсолютный порог «слотов достаточно» (меньше — тревога)
SLOT_THRESHOLD_ABSOLUTE=5
# Относительный порог «слотов достаточно» (доля от общего числа слотов)
SLOT_THRESHOLD_PERCENTAGE=0.25

# === TTL сообщений ===
# Время жизни сообщений в кэше (секунд, 604800 = 7 дней)
MESSAGE_TTL_SECONDS=604800

# === Mini App ===
# Включить аутентификацию Mini App (True/False)
MINI_APP_AUTH_ENABLED=True
