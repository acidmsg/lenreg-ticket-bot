# Telegram Bot Token
BOT_TOKEN=your_telegram_bot_token_here

# Proxy Configuration
# Используйте "auto" как хост для автоопределения IP прокси при старте
# (сканирование Docker/WSL подсетей 172.17-31.0.0/16 на заданном порту)
# Для фиксированного адреса: socks5://172.17.16.1:10808
PROXY_URL=socks5://auto:10808

# File Paths
SQLITE_DB_PATH=data/bot.db
CACHE_PATH=data/monitoring_cache.json

# Redis
REDIS_URL=redis://localhost:6379/0

# Patient IDs for doctor discovery (used to fetch speciality lists)
DISCOVERY_PATIENT_ID_ADULT=your_adult_patient_id_here
DISCOVERY_PATIENT_ID_CHILD=your_child_patient_id_here

# Admin Telegram ID(s) for /status command (comma-separated, e.g.: your_telegram_id or your_telegram_id,another_id)
ADMIN_IDS=your_telegram_id_here

# === Error notifications (M2) ===
# Enable/disable error notifications globally (can be overridden in DB config)
ERROR_NOTIFY_ENABLED=True

# NTFY topic URL for push notifications — SECRET
NTFY_TOPIC_URL=your_ntfy_topic_url_here

# Sentry DSN for error tracking — SECRET
SENTRY_DSN=your_sentry_dsn_here

# Environment tag for Sentry (can be overridden in DB config)
ENVIRONMENT=production

# Пороги для форматирования списка номерков
# Макс. слотов на одну дату для детального отображения (больше — диапазон)
SLOT_DETAIL_THRESHOLD=10
# Макс. слотов всего для детального отображения (больше — компактно)
SLOT_COMPACT_THRESHOLD=15

# === Rate limiting (M3) ===
# Max messages per user per time window (can be overridden in DB config)
USER_RATE_LIMIT_MAX=30
USER_RATE_LIMIT_PERIOD=60

# === Metrics (Prometheus) ===
# Порт для HTTP-endpoint /metrics
METRICS_PORT=9090

# === API Versioning ===
# Версия API-клиента (передаётся в заголовке X-Client-Version)
API_VERSION=1.0.0
# Валидация ответов API через Pydantic-схемы (True/False)
API_VALIDATE_RESPONSES=True

# === API zdrav.lenreg.ru ===
# Базовый URL API портала zdrav.lenreg.ru
API_BASE_URL=https://zdrav.lenreg.ru/api

# Referer для HTTP-заголовков
REFERER_URL=https://zdrav.lenreg.ru/signup/free/

# Origin для HTTP-заголовков
ORIGIN_URL=https://zdrav.lenreg.ru

# CSRF-токен для запросов к API — SECRET, placeholder
CSRF_TOKEN=your_csrf_token_here

# ID района по умолчанию для получения списка клиник
DISTRICT_ID=4

# === Идентификаторы по умолчанию ===
# Клиника по умолчанию для первичного поиска пациента
DEFAULT_CLINIC_ID=272

# ID стоматологической клиники (для фильтрации детских/взрослых специальностей)
DENTAL_CLINIC_ID=272

# Дефолтная дата рождения для новых пациентов без даты
DEFAULT_BIRTHDAY=1990-01-01

# Публичная ссылка для записи (отображается в уведомлениях)
SIGNUP_URL=https://zdrav.lenreg.ru/signup/free/

# === Python / Encoding ===

# Включает Python UTF-8 Mode (PEP 540) — sys.stdout.encoding = utf-8
# Устраняет кракозябры в pwsh на Windows с русской локалью.
PYTHONUTF8=1
