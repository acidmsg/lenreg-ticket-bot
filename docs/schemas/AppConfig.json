{
  "description": "Параметры конфигурации бота. Загружаются из .env через Settings, переопределяются из таблицы config БД.",
  "properties": {
    "BOT_TOKEN": {
      "type": "string",
      "description": "Токен Telegram-бота (только .env)"
    },
    "SQLITE_DB_PATH": { "type": "string", "default": "data/bot.db" },
    "CACHE_PATH": { "type": "string", "default": "data/monitoring_cache.json" },
    "PROXY_URL": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "description": "SOCKS5-прокси для Telegram API"
    },
    "API_BASE_URL": { "type": "string", "default": "https://zdrav.lenreg.ru/api" },
    "REFERER_URL": {
      "type": "string",
      "default": "https://zdrav.lenreg.ru/signup/free/"
    },
    "CSRF_TOKEN": { "type": "string", "default": "NOTPROVIDED" },
    "API_TIMEOUT": {
      "type": "number",
      "default": 10.0,
      "description": "Таймаут HTTP-запросов к API (секунд)"
    },
    "CHECK_INTERVAL": {
      "type": "integer",
      "default": 300,
      "description": "Интервал healthcheck (секунд)"
    },
    "DISCOVERY_INTERVAL": {
      "type": "integer",
      "default": 1800,
      "description": "Интервал discovery врачей (секунд, 30 минут)"
    },
    "SLOT_THRESHOLD_ABSOLUTE": {
      "type": "integer",
      "default": 5,
      "description": "Абсолютный порог: уведомлять, если слотов стало < N"
    },
    "SLOT_THRESHOLD_PERCENTAGE": {
      "type": "number",
      "default": 0.25,
      "description": "Процентный порог: уведомлять при уменьшении на ≥ 25%"
    },
    "DISCOVERY_PATIENT_ID_ADULT": {
      "type": "string",
      "description": "ID взрослого discovery-пациента"
    },
    "DISCOVERY_PATIENT_ID_CHILD": {
      "type": "string",
      "description": "ID детского discovery-пациента"
    },
    "DEFAULT_CLINIC_ID": {
      "type": "string",
      "default": "272",
      "description": "Клиника по умолчанию для первичного поиска пациента"
    },
    "DEFAULT_BIRTHDAY": {
      "type": "string",
      "default": "1990-01-01",
      "description": "Дата рождения по умолчанию"
    },
    "ADMIN_IDS": { "type": "string", "description": "ID админов через запятую" },
    "MESSAGE_TTL_SECONDS": {
      "type": "integer",
      "default": 604800,
      "description": "TTL автоудаления сообщений (7 дней)"
    },
    "CLEANUP_INTERVAL": {
      "type": "integer",
      "default": 3600,
      "description": "Интервал проверки автоудаления (секунд)"
    },
    "ERROR_NOTIFY_ENABLED": {
      "type": "boolean",
      "default": true,
      "description": "Включить уведомления об ошибках (NTFY/Sentry)"
    },
    "ENVIRONMENT": { "type": "string", "default": "production" },
    "USER_RATE_LIMIT_MAX": {
      "type": "integer",
      "default": 30,
      "description": "Максимум сообщений от пользователя за период"
    },
    "USER_RATE_LIMIT_PERIOD": {
      "type": "integer",
      "default": 60,
      "description": "Период скользящего окна rate limiter (секунд)"
    },
    "REDIS_URL": {
      "type": "string",
      "default": "redis://localhost:6379/0",
      "description": "URL Redis-сервера для кэширования"
    },
    "REDIS_PASSWORD": { "type": "string", "description": "Пароль Redis (только .env)" },
    "SLOT_DETAIL_THRESHOLD": {
      "type": "integer",
      "default": 10,
      "description": "Если слотов на одну дату > этого порога — показываем диапазон"
    },
    "SLOT_COMPACT_THRESHOLD": {
      "type": "integer",
      "default": 15,
      "description": "Если всего слотов > этого порога — показываем компактно по датам"
    },
    "DENTAL_CLINIC_ID": {
      "type": "string",
      "default": "272",
      "description": "ID стоматологической клиники"
    },
    "ORIGIN_URL": {
      "type": "string",
      "default": "https://zdrav.lenreg.ru",
      "description": "Origin для HTTP-заголовков"
    },
    "DISTRICT_ID": {
      "type": "string",
      "default": "4",
      "description": "ID района по умолчанию для списка клиник"
    },
    "SIGNUP_URL": {
      "type": "string",
      "default": "https://zdrav.lenreg.ru/signup/free/",
      "description": "Публичная ссылка для записи"
    },
    "NTFY_TOPIC_URL": {
      "type": "string",
      "description": "NTFY topic URL для push-уведомлений (только .env)"
    },
    "SENTRY_DSN": {
      "type": "string",
      "description": "Sentry DSN для отслеживания ошибок (только .env)"
    },
    "METRICS_PORT": {
      "type": "integer",
      "default": 9090,
      "description": "Порт для HTTP-endpoint /metrics (Prometheus)"
    },
    "API_VERSION": {
      "type": "string",
      "default": "1.0.0",
      "description": "Версия API-клиента"
    },
    "API_VALIDATE_RESPONSES": {
      "type": "boolean",
      "default": true,
      "description": "Валидация ответов API через Pydantic-схемы"
    },
    "BOT_LANGUAGE": {
      "type": "string",
      "default": "ru",
      "description": "Язык интерфейса бота (ru, en)"
    },
    "SCHEMA_CHECK_INTERVAL": {
      "type": "integer",
      "default": 3600,
      "description": "Интервал проверки схем API (секунд)"
    },
    "SCHEMA_CHECK_ENABLED": {
      "type": "boolean",
      "default": true,
      "description": "Включить проверку схем API"
    },
    "WEB_DASHBOARD_ENABLED": {
      "type": "boolean",
      "default": true,
      "description": "Включить веб-дашборд"
    },
    "WEB_DASHBOARD_PORT": {
      "type": "integer",
      "default": 8090,
      "description": "Порт для веб-дашборда"
    },
    "WEB_DASHBOARD_API_KEY": {
      "type": "string",
      "description": "API-ключ для доступа к дашборду (только .env)"
    }
  },
  "title": "AppConfig",
  "type": "object"
}
