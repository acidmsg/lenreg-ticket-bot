{
  "description": "Информация о пользователе Telegram",
  "properties": {
    "uid": { "type": "string", "description": "ID пользователя Telegram" },
    "patient_count": {
      "type": "integer",
      "description": "Количество пациентов пользователя"
    },
    "monitoring_count": {
      "type": "integer",
      "description": "Количество отслеживаемых врачей"
    },
    "last_activity_ts": {
      "type": "number",
      "description": "Unix-timestamp последней активности"
    },
    "patients": {
      "type": "object",
      "description": "Словарь пациентов (только в детальном ответе)",
      "additionalProperties": { "$ref": "DB_Patient.json" }
    },
    "monitoring": {
      "type": "object",
      "description": "Словарь мониторинга (только в детальном ответе)"
    },
    "last_messages": {
      "type": "object",
      "description": "Словарь последних сообщений (только в детальном ответе)"
    }
  },
  "title": "UserInfo",
  "type": "object"
}
