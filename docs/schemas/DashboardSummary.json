{
  "description": "Сводка состояния системы (эндпоинт /api/dashboard/summary)",
  "properties": {
    "uptime": {
      "type": "string",
      "description": "Время работы в человекочитаемом формате"
    },
    "uptime_seconds": { "type": "number", "description": "Время работы в секундах" },
    "total_users": { "type": "integer", "description": "Всего пользователей" },
    "total_patients": { "type": "integer", "description": "Всего пациентов" },
    "total_monitored_doctors": {
      "type": "integer",
      "description": "Всего отслеживаемых врачей"
    },
    "active_monitorings": {
      "type": "integer",
      "description": "Количество активных мониторингов"
    },
    "api_status": {
      "type": "object",
      "description": "Статус внешнего API zdrav.lenreg.ru",
      "properties": {
        "accessible": { "type": "boolean" },
        "last_check_seconds_ago": { "type": "integer" },
        "total_checks": { "type": "integer" },
        "total_errors": { "type": "integer" },
        "availability_pct": { "type": "number" }
      }
    },
    "background_tasks": {
      "type": "object",
      "description": "Состояние фоновых asyncio-задач",
      "properties": {
        "monitor_loop": { "type": "string", "enum": ["alive", "dead"] },
        "discovery_tasks": { "type": "integer" },
        "healthcheck_loop": { "type": "string", "enum": ["alive", "dead"] },
        "cleanup_loop": { "type": "string", "enum": ["alive", "dead"] },
        "schema_check_loop": { "type": "string", "enum": ["alive", "dead"] }
      }
    },
    "recent_alerts": {
      "type": "array",
      "description": "Последние записи лога мониторинга",
      "items": { "$ref": "LogEntry.json" }
    }
  },
  "title": "DashboardSummary",
  "type": "object"
}
