# ── Кэш конфигов, загруженных из БД ──────────────────────────

_db_config_cache: dict[str, str] = {}

# Список ключей, которые переопределяются из БД
DB_CONFIG_KEYS = [
    "slot_threshold_absolute",
    "slot_threshold_percentage",
    "check_interval",
    "discovery_interval",
    "discovery_patient_id_adult",
    "discovery_patient_id_child",
    "default_clinic_id",
    "default_birthday",
    "message_ttl_seconds",
    "cleanup_interval",
    "api_base_url",
    "referer_url",
    "csrf_token",
    "api_timeout",
]


async def load_config_from_db(db):
    """Загружает конфиги из таблицы config в кэш."""
    global _db_config_cache
    try:
        _db_config_cache = await db.get_all_config()
        _apply_db_config()
    except Exception as e:
        import logging

        logging.getLogger(__name__).warning(
            f"Не удалось загрузить конфиги из БД: {e}. Используются значения по умолчанию."
        )


def get_db_config(key: str, default: str = "") -> str:
    """Возвращает значение конфига из кэша БД или пустую строку."""
    return _db_config_cache.get(key, default)


def get_db_config_int(key: str, default: int = 0) -> int:
    """Возвращает целочисленное значение конфига из кэша БД."""
    val = _db_config_cache.get(key)
    if val is None:
        return default
    try:
        return int(val)
    except (ValueError, TypeError):
        return default


def get_db_config_float(key: str, default: float = 0.0) -> float:
    """Возвращает float-значение конфига из кэша БД."""
    val = _db_config_cache.get(key)
    if val is None:
        return default
    try:
        return float(val)
    except (ValueError, TypeError):
        return default


def _apply_db_config():
    """Применяет загруженные из БД конфиги к объекту settings."""
    global _db_config_cache
    if not _db_config_cache:
        return

    int_keys = {
        "slot_threshold_absolute": "SLOT_THRESHOLD_ABSOLUTE",
        "check_interval": "CHECK_INTERVAL",
        "discovery_interval": "DISCOVERY_INTERVAL",
        "message_ttl_seconds": "MESSAGE_TTL_SECONDS",
        "cleanup_interval": "CLEANUP_INTERVAL",
        "api_timeout": "API_TIMEOUT",
    }
    str_keys = {
        "discovery_patient_id_adult": "DISCOVERY_PATIENT_ID_ADULT",
        "discovery_patient_id_child": "DISCOVERY_PATIENT_ID_CHILD",
        "default_clinic_id": "DEFAULT_CLINIC_ID",
        "default_birthday": "DEFAULT_BIRTHDAY",
        "api_base_url": "API_BASE_URL",
        "referer_url": "REFERER_URL",
        "csrf_token": "CSRF_TOKEN",
    }
    float_keys = {
        "slot_threshold_percentage": "SLOT_THRESHOLD_PERCENTAGE",
    }

    for db_key, attr_name in int_keys.items():
        if db_key in _db_config_cache:
            try:
                setattr(settings, attr_name, int(_db_config_cache[db_key]))
            except (ValueError, TypeError):
                pass

    for db_key, attr_name in str_keys.items():
        if db_key in _db_config_cache:
            setattr(settings, attr_name, _db_config_cache[db_key])

    for db_key, attr_name in float_keys.items():
        if db_key in _db_config_cache:
            try:
                setattr(settings, attr_name, float(_db_config_cache[db_key]))
            except (ValueError, TypeError):
                pass
