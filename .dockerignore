# Исключения для Docker-сборки.
# В образ попадают только файлы, необходимые для запуска бота в рантайме.
# Служебные, сборочные и CI/CD-файлы исключены для минимального размера образа.
# Секция !pyproject.toml / !poetry.lock вручную включает их обратно —
# они нужны Poetry для установки зависимостей.

# Git
.git/
.gitignore
.gitattributes

# Virtual environment
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# IDE / Editor
.vscode/
.history/
.idea/
*.swp
*.swo

# Project config (not needed in runtime image)
.roo/
.clinerules
.markdownlint.json
.pre-commit-config.yaml
pyrightconfig.json
pytest.ini
poetry.lock
pyproject.toml

# === Необходимы для Docker-сборки (установка зависимостей через Poetry) ===
!pyproject.toml
!poetry.lock
Makefile
package.json
tasks.ps1

# Tests
tests/

# Documentation / Specifications
specs/
plans/
artifacts/
README.md

# Design Lab
_design_lab/

# CI/CD
.github/

# Agent configs
.agents/

# Linting config (not needed in runtime)
stylelint.config.mjs

# Node (for markdownlint/prettier)
node_modules/
dist/
package-lock.json

# Runtime data (created by container volume)
data/
logs/

# Environment (real .env must NOT be in image)
.env

# Temp files
*.tmp
.tmp_*

# Scripts
scripts/
